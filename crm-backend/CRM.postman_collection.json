{
  "info": {
    "name": "CRM Software API",
    "description": "API collection for the Spring Boot CRM Software project (Month 4)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "User Management & Auth",
      "item": [
        {
          "name": "Register (Sales Rep)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Sarah Sales\",\n  \"email\": \"sarah@crm.com\",\n  \"password\": \"password123\",\n  \"role\": \"SALES\"\n}"
            }
          }
        },
        {
          "name": "Login (default admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@crm.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        }
      ]
    },
    {
      "name": "Customer Management",
      "item": [
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/customers"
          }
        },
        {
          "name": "Get Customer By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/customers/1"
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"email\": \"contact@acme.com\",\n  \"phone\": \"9876543210\",\n  \"company\": \"Acme Corporation\",\n  \"address\": \"123 Main St\",\n  \"notes\": \"Interested in enterprise plan\"\n}"
            }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/customers/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"email\": \"contact@acme.com\",\n  \"phone\": \"9876543210\",\n  \"company\": \"Acme Corporation\",\n  \"address\": \"456 New Address\",\n  \"notes\": \"Upgraded to enterprise plan\"\n}"
            }
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/customers/1"
          }
        }
      ]
    },
    {
      "name": "Lead Management",
      "item": [
        {
          "name": "Get All Leads",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/leads"
          }
        },
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/leads",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Prospect\",\n  \"contactInfo\": \"john@prospect.com\",\n  \"source\": \"WEB\",\n  \"status\": \"NEW\"\n}"
            }
          }
        },
        {
          "name": "Update Lead",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/leads/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Prospect\",\n  \"contactInfo\": \"john@prospect.com\",\n  \"source\": \"WEB\",\n  \"status\": \"CONTACTED\"\n}"
            }
          }
        },
        {
          "name": "Delete Lead",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/leads/1"
          }
        }
      ]
    },
    {
      "name": "Task Management",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Follow up call\",\n  \"description\": \"Call the prospect about pricing\",\n  \"dueDate\": \"2026-07-10\",\n  \"priority\": \"HIGH\",\n  \"status\": \"OPEN\"\n}"
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/tasks/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Follow up call\",\n  \"description\": \"Call the prospect about pricing\",\n  \"dueDate\": \"2026-07-10\",\n  \"priority\": \"HIGH\",\n  \"status\": \"COMPLETED\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks/1"
          }
        }
      ]
    },
    {
      "name": "Sales Management",
      "item": [
        {
          "name": "Get All Sales",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/sales"
          }
        },
        {
          "name": "Get Sale By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/sales/1"
          }
        },
        {
          "name": "Create Sale",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sales",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"amount\": 15000,\n  \"status\": \"PROPOSAL\",\n  \"date\": \"2026-07-02\"\n}"
            }
          }
        },
        {
          "name": "Update Sale",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sales/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"amount\": 15000,\n  \"status\": \"CLOSED_WON\",\n  \"date\": \"2026-07-02\"\n}"
            }
          }
        }
      ]
    }
  ]
}
